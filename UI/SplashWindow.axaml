        x:Class="FiveCardDraw.SplashWindow"
        SystemDecorations="None"
        Background="Black"
        CanResize="False"
        WindowStartupLocation="CenterScreen">
    <Image Name="SplashImage" Stretch="Uniform" />
</Window>
